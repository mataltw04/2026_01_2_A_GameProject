    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "2581e9d5554246a09da849fad379fbb2",
    "m_Title": "화면 왜곡하는 기반",
    "m_Content": "화면 좌표를 노이즈로 살짝 흔들어서 왜곡 효과를 만드는 구조\n\n기존 화면 좌표 + 노이즈 기반 오프셋 = 왜곡한 좌표\n\n픽셀 위치를 살짝 밀어버림",
    "m_TextSize": 0,
    "m_Theme": 0,
